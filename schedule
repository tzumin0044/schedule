            const s = new Set();
            this.appData.forEach(i => i.groupName && s.add(i.groupName));
            return Array.from(s).sort();
        },
        filteredData() {
            const res = {};
            for (let c in this.rawData) {
                if (this.activeCategory === "ALL" || this.activeCategory === c) {
                    res[c] = [...this.rawData[c]];
                    if (this.selectedGroupName) {
                        res[c].sort((a,b) => (b.groupName===this.selectedGroupName)-(a.groupName===this.selectedGroupName));
                    }
                }
            }
            return res;
        }
    },
    created() {
        const saved = localStorage.getItem('fresh_sys_v4');
        this.appData = saved ? JSON.parse(saved) : JSON.parse(JSON.stringify(full66List));
        this.buildRawData();
    },
    methods: {
        buildRawData() {
            const tmp = {};
            this.appData.forEach(i => {
                if(!tmp[i.cat]) tmp[i.cat] = [];
                tmp[i.cat].push({...i, tempQty: null, tempStaff: 1, checked: false});
            });
            this.rawData = tmp;
        },
        enterSettings() { this.editingData = JSON.parse(JSON.stringify(this.appData)); this.isSettingMode = true; },
        addNewItem() { this.editingData.unshift({cat:"新類別", name:"新名", unit:"kg", eff:10, groupName:""}); },
        saveSettings() { 
            this.appData = JSON.parse(JSON.stringify(this.editingData));
            localStorage.setItem('fresh_sys_v4', JSON.stringify(this.appData));
            this.buildRawData(); this.isSettingMode = false;
        },
        handleGroupSelect() {
            if(!this.selectedGroupName) return;
            Object.values(this.rawData).forEach(c => c.forEach(i => { if(i.groupName===this.selectedGroupName) i.checked=true; }));
        },
        syncStaff() {
            Object.values(this.rawData).forEach(c => c.forEach(i => { if(i.checked) i.tempStaff = this.globalStaff; }));
        },
        clearAll() {
            Object.values(this.rawData).forEach(c => c.forEach(i => { i.checked=false; i.tempQty=null; i.tempStaff=1; }));
        },
        batchAdd() {
            const picked = [];
            Object.values(this.rawData).forEach(c => c.forEach(i => {
                if(i.checked && i.tempQty > 0) { picked.push({...i}); i.checked=false; i.tempQty=null; }
            }));
            if(!picked.length) return;

            const groups = {};
            const solos = [];
            picked.forEach(p => p.groupName ? (groups[p.groupName] = groups[p.groupName] || []).push(p) : solos.push(p));

            for (let g in groups) {
                let h = 0; const s = groups[g][0].tempStaff;
                const items = groups[g].map(p => { 
                    h += (p.tempQty/(p.eff*s)); 
                    return {name:p.name, unit:p.unit, qty:p.tempQty}; 
                });
                this.unassignedTasks.unshift({id:Date.now()+Math.random(), title:`📦 ${g}群組`, isGroup:true, items, staff:s, hours:h.toFixed(2)});
            }
            solos.forEach(p => {
                const h = (p.tempQty/(p.eff*p.tempStaff));
                this.unassignedTasks.unshift({id:Date.now()+Math.random(), title:p.name, isGroup:false, items:[{name:p.name, unit:p.unit, qty:p.tempQty}], staff:p.tempStaff, hours:h.toFixed(2)});
            });
        },
        getBoardTotal(b) { return b.tasks.reduce((s, t) => s + parseFloat(t.hours), 0).toFixed(2); },
        getPercent(b) { const cap = b.staffCount*8; return cap ? Math.round((this.getBoardTotal(b)/cap)*100) : 0; },
        getBarClass(b) { const p = this.getPercent(b); return p > 100 ? 'bg-danger' : (p > 80 ? 'bg-warning' : 'bg-safe'); }
    }
});
</script>
